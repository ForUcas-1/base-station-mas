# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# === LLM Provider (anthropic | openai | deepseek) ===
LLM_PROVIDER=deepseek

# === LLM Model (所有 Worker 共用，改一处即可) ===
LLM_MODEL=deepseek-v4-pro

# === Paths (relative to project root) ===
DATA_CACHE_DIR=data/cache
CHECKPOINT_DIR=data/checkpoints
KG_TOPOLOGY_PATH=knowledge_graph/topology.json
KG_EMBEDDINGS_DIR=knowledge_graph/embeddings

# === Server ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# === Detection Worker Defaults ===
DETECTION_ENCODER=TimesNet
DETECTION_THRESHOLD=0.5
DETECTION_CHECKPOINT=detection_timesnet.pt

# === Diagnosis Worker Defaults ===
DIAGNOSIS_ENCODER=Autoformer
DIAGNOSIS_CHECKPOINT=rootcause_autoformer.pt
